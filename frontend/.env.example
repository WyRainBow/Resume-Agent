VITE_ENV_DEFAULT=local
VITE_API_BASE_URL_LOCAL=http://127.0.0.1:9000
VITE_API_BASE_URL_REMOTE_DEV=https://resumegenkk.xyz
VITE_AGENT_ENABLED=false
VITE_AGENT_ASKING_MODE_ENABLED=false

# REQUIRED: BetterAuth (Next.js web) is the ONLY login since 2026-07-17 —
# the legacy FastAPI JWT login has been fully removed. Every deployment must
# run the web service and set this URL, or login will be unavailable.
VITE_AUTH_WEB_URL=http://localhost:3000

# Configuring VITE_AUTH_WEB_URL also routes business APIs through the Next.js
# /api/fastapi/proxy path, so BetterAuth cookies can be handed off to FastAPI.
