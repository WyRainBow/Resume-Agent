VITE_ENV_DEFAULT=local
VITE_API_BASE_URL_LOCAL=http://127.0.0.1:9000
VITE_API_BASE_URL_REMOTE_DEV=https://resumegenkk.xyz
VITE_AGENT_ENABLED=false

# Set this to let the legacy Vite login page/modal hand off to Next.js + BetterAuth.
# Leave it empty to keep using the existing FastAPI JWT login while migrating.
VITE_AUTH_WEB_URL=http://localhost:3000

# Optional: route Vite API calls through Next.js so BetterAuth sessions can be
# forwarded to FastAPI server-side. Leave disabled until the auth stack is fully configured.
# When VITE_AUTH_WEB_URL is set, browser requests include credentials so BetterAuth cookies
# can reach the Next.js proxy across localhost ports.
VITE_API_VIA_AUTH_WEB=false
