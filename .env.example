# Minimal local setup
DEFAULT_AI_PROVIDER=kimi
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding
KIMI_API_FORMAT=anthropic-messages
KIMI_MODEL=kimi-for-coding

# Optional alternative providers
DASHSCOPE_API_KEY=
JWT_SECRET_KEY=change-this-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# Optional AI providers
ZHIPU_API_KEY=
DOUBAO_API_KEY=

# Optional model overrides
DEEPSEEK_MODEL=deepseek-v3.2
DEEPSEEK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DOUBAO_MODEL=doubao-seed-1-6-lite-251015
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ZHIPU_VISION_MODEL=glm-4.6v
ZHIPU_OCR_MODEL=glm-ocr

# Database
# If none of the following are set, backend falls back to SQLite at backend/resume.db
# DATABASE_URL=mysql+pymysql://user:password@127.0.0.1:3306/resume_db
# USE_POSTGRESQL=true
# POSTGRESQL_URL=postgresql+psycopg://postgres:password@127.0.0.1:5432/resume_db

# Semantic search / embeddings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# COS object storage
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=

# Logging
LOG_MODE=console
LOG_LEVEL=INFO
LOG_DIR=logs

# Optional behavior switches
LOGO_AUTO_SYNC_ON_STARTUP=true
AGENT_HISTORY_BACKEND=file

# Optional agent proxy mode
# AGENT_BACKEND_BASE_URL=http://127.0.0.1:9100

# Optional JWT settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
