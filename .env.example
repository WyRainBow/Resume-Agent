# ============================================================
# Resume-Agent 后端环境变量
# 复制本文件为 .env，填入你自己的 key 即可本地运行。
# ============================================================

# ---- LLM / AI 模型（必填至少一组）----
# DeepSeek / Qwen 走 DashScope 兼容通道，同一把 key 即可
DASHSCOPE_API_KEY=

# 智谱 GLM（OCR / 视觉布局识别，PDF 与图片导入必需）
ZHIPU_API_KEY=

# 可选：豆包模型（留空则不启用）
DOUBAO_API_KEY=

# 可选：OpenAI 兼容模型（留空则不启用）
OPENAI_API_KEY=

# ---- 安全密钥 ----
# JWT 签名用，本地随便填一串随机字符即可
JWT_SECRET_KEY=change-me-to-a-random-string

# 邮箱发信凭据加密密钥（仅发邮件功能用到，可留空）
EMAIL_CREDENTIAL_ENC_KEY=

# ---- 腾讯云 COS（可选，用于公司 Logo 与头像存储）----
COS_SECRET_KEY=

# ---- 数据库（可选，默认走 SQLite；填了则用 PostgreSQL）----
# USE_POSTGRESQL=false
# POSTGRESQL_URL=postgresql+psycopg2://user:password@localhost:5432/resume_db
