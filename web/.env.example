BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32

# Prefer this for the Next.js auth layer. It can point to the same PostgreSQL database used by FastAPI.
BETTER_AUTH_DATABASE_URL=postgresql://resume_user:password@localhost:5432/resume_db

# Compatibility with the course naming.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Optional client override when the auth server is not same-origin.
NEXT_PUBLIC_AUTH_BASE_URL=

# FastAPI stays as the business API.
NEXT_PUBLIC_FASTAPI_BASE_URL=http://127.0.0.1:9000
FASTAPI_INTERNAL_BASE_URL=http://127.0.0.1:9000
FASTAPI_INTERNAL_AUTH_SECRET=replace-with-shared-internal-secret

# Comma-separated browser origins allowed to call /api/fastapi/* during migration.
AUTH_PROXY_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Where users land after sign-in when no returnTo query param is provided.
AUTH_DEFAULT_RETURN_TO=http://localhost:5173/workspace
